<% page_title "Blog | Polska Organizacja Aikido" if blog_current_page == 1 %>

<div class="content">
  <div class="article">
    <h1>Blog</h1>
    <% if blog_current_page == 1 %>
      <p class="lead">
        Miejsce na komunikaty dojo, relacje z wydarzeń, zapowiedzi seminariów i praktyczne wpisy dla trenujących.
      </p>
    <% else %>
      <p class="lead">Starsze wpisy (strona <%= blog_current_page %>).</p>
    <% end %>

    <div class="news-list">
      <% blog_posts_for_current_page.each do |post| %>
        <article class="news-card">
          <div class="news-meta"><%= post[:date] %></div>
          <h2><a href="<%= post[:url] %>"><%= post[:title] %></a></h2>
          <p><%= post[:summary] %></p>
          <a class="news-read-more" href="<%= post[:url] %>">Czytaj więcej →</a>
        </article>
      <% end %>
    </div>

    <% if blog_total_pages > 1 %>
      <nav class="pagination" aria-label="Paginacja bloga">
        <% if blog_current_page > 1 %>
          <a class="pagination-link pagination-prev" href="<%= blog_page_path(blog_current_page - 1) %>">← Poprzednia</a>
        <% end %>

        <% blog_page_numbers.each do |page| %>
          <% if page == blog_current_page %>
            <span class="pagination-link is-active" aria-current="page"><%= page %></span>
          <% else %>
            <a class="pagination-link" href="<%= blog_page_path(page) %>"><%= page %></a>
          <% end %>
        <% end %>

        <% if blog_current_page < blog_total_pages %>
          <a class="pagination-link pagination-next" href="<%= blog_page_path(blog_current_page + 1) %>">Następna →</a>
        <% end %>
      </nav>
    <% end %>
  </div>
</div>
