  <div class="home-section">
    <h2>Najnowsze wpisy</h2>

    <div class="news-list home-news-list">
      <% blog_posts(language: "pl").first(3).each do |post| %>
        <article class="news-card">
          <div class="news-meta"><%= post[:date] %></div>
